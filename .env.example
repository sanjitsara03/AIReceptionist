# Copy this file to `.env` and fill in real values.
# Required variables have no defaults — the app will fail to start without them.
# Optional ones list their default in the comment.

# ----- Database & Redis (required) -----
DATABASE_URL=postgresql+asyncpg://receptionist:receptionist@localhost:5432/receptionist
REDIS_URL=redis://localhost:6379

# ----- App secrets (required) -----
SECRET_KEY=change-me-to-something-long-and-random
ENVIRONMENT=development  # default: development. Set to "production" on prod hosts. Used for Sentry tagging.

# ----- Twilio (required for SMS / voice) -----
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# ----- Anthropic / Claude API (required) -----
ANTHROPIC_API_KEY=sk-ant-api03-...

# ----- Auth0 (required) -----
# Get these from your Auth0 application:
#   Domain & Client ID:  Applications → [your app] → Settings → Basic Information
#   Audience:            APIs → [your API] → Settings → Identifier
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_AUDIENCE=https://api.aireceptionist.io

# ----- Admin operations (required) -----
# Used to authenticate POST /invites requests via the X-Admin-Secret header.
# Generate a long random string — at least 32 chars.
ADMIN_SECRET=change-me-to-something-long-and-random

# ----- Sentry error tracking (optional) -----
# If unset, Sentry init is a no-op. Get a DSN by creating a FastAPI project at sentry.io.
SENTRY_DSN=

# ----- CORS allowlist (optional) -----
# Comma-separated list of origins allowed to call the API from a browser.
# Default covers local Vite dev on its two common ports.
# In production, set to your deployed frontend origin, e.g.:
#   ALLOWED_ORIGINS=https://aireceptionist.vercel.app
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# ----- Frontend URL (optional) -----
# Where the frontend lives — used to generate invite links shown to new business owners.
# Default is local Vite dev.
FRONTEND_URL=http://localhost:5173
